# GPU-enabled image for headroom-ai.
#
# Base: NVIDIA CUDA 12.4.1 + cuDNN 9 runtime on Ubuntu 22.04.
# Includes the full ML extra set (torch, sentence-transformers, SigLIP,
# fastembed, onnxruntime-gpu) plus the SmartCrusher Rust extension
# (`headroom._core`) so JSON compression actually runs.
#
# Run with: docker run --gpus all -p 8787:8787 ghcr.io/orq-ai/headroom-internal:gpu
#
# Build prerequisites: BuildKit (DOCKER_BUILDKIT=1) — required for the
# `--mount=type=cache` directives.
#
# Notes / gotchas:
# 1. headroom-ai is the PyPI package name. We install from local checkout
#    (./) so source is actually present.
# 2. `headroom._core` is a PyO3/maturin extension under
#    `crates/headroom-py/`. Not installed by `pip install`. Without it,
#    SmartCrusher is disabled and JSON payloads pass through uncompressed.
# 3. tree-sitter-language-pack >= 1.6.3 renamed its module to `_native`.
#    headroom imports the old name; pin < 1.6.3.
# 4. Rust toolchain must be `stable` (>=1.85). 1.80 fails on edition2024
#    deps (clap_builder).
# 5. esaxx-rs (transitive) compiles C++ -> needs g++. openssl-sys
#    needs pkg-config + libssl-dev.
# 6. With [ml], we bake HF weights and set TRANSFORMERS_OFFLINE so the
#    proxy never reaches out at runtime.
# 7. Multi-stage: builder has full toolchain (Rust, gcc, dev headers);
#    runtime carries only Python + CUDA/cuDNN libs + installed wheels.

# CUDA 12.6.3 + Ubuntu 24.04 ships python3.12 in main repos — avoids the
# deadsnakes PPA entirely (the python3.11 path on jammy hit launchpad
# SSL/connection failures during build).
ARG CUDA_VERSION=12.6.3
ARG UBUNTU_VERSION=24.04
ARG PYTHON_VERSION=3.12
ARG UV_VERSION=0.6.17

# ---------- Stage 1: builder ----------
FROM nvidia/cuda:${CUDA_VERSION}-cudnn-runtime-ubuntu${UBUNTU_VERSION} AS builder

ARG PYTHON_VERSION
ARG UV_VERSION
# Default extras enable: SmartCrusher (always, via Rust ext), CCR
# (magika; in [proxy]), Kompress GPU compression ([ml]), AST code
# compression ([code]), smart cache + hierarchical memory with vector
# search ([memory] → hnswlib + sqlite-vec + sentence-transformers),
# semantic relevance scoring / context reranking ([relevance] →
# fastembed). Dropped: [image] (no image compression workflow). Override
# via --build-arg HEADROOM_EXTRAS=... if needed.
ARG HEADROOM_EXTRAS="proxy,code,ml,memory,relevance"

ENV DEBIAN_FRONTEND=noninteractive \
    PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PIP_NO_CACHE_DIR=1 \
    HF_HOME=/opt/hf-cache

# Apt retry config for flaky networks (deadsnakes / launchpad).
RUN echo 'Acquire::Retries "3";' > /etc/apt/apt.conf.d/80-retries && \
    echo 'Acquire::http::Timeout "30";' >> /etc/apt/apt.conf.d/80-retries && \
    echo 'Acquire::ForceIPv4 "true";' >> /etc/apt/apt.conf.d/80-retries

RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        curl \
        ca-certificates \
        build-essential \
        gcc \
        g++ \
        libc6-dev \
        pkg-config \
        libssl-dev \
        python${PYTHON_VERSION} \
        python${PYTHON_VERSION}-dev \
        python${PYTHON_VERSION}-venv \
        python3-pip && \
    ln -sf /usr/bin/python${PYTHON_VERSION} /usr/local/bin/python && \
    ln -sf /usr/bin/python${PYTHON_VERSION} /usr/local/bin/python3 && \
    rm -f /usr/lib/python${PYTHON_VERSION}/EXTERNALLY-MANAGED && \
    rm -rf /var/lib/apt/lists/*

# Rust toolchain. The repo pins via rust-toolchain.toml (1.95.0); install
# stable here so rustup picks it up. rust-toolchain.toml will trigger
# rustup to fetch the pinned version on first cargo invocation.
RUN curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs \
    | sh -s -- -y --default-toolchain stable --profile minimal
ENV PATH="/root/.cargo/bin:${PATH}"

RUN python -m pip install uv==${UV_VERSION} "maturin[patchelf]"

WORKDIR /build

COPY pyproject.toml uv.lock README.md Cargo.toml Cargo.lock rust-toolchain.toml ./
COPY crates/ crates/
RUN mkdir -p headroom && touch headroom/__init__.py
RUN --mount=type=cache,target=/root/.cache/uv \
    uv pip install --system ".[${HEADROOM_EXTRAS}]"

# Pin tree-sitter-language-pack below the 1.6.3 module rename.
RUN --mount=type=cache,target=/root/.cache/uv \
    uv pip install --system "tree-sitter-language-pack>=0.10.0,<1.6.3"

# Replace CPU onnxruntime with CUDA build.
# Pin <1.27: onnxruntime-gpu 1.27.0 made libcudart.so.13 a hard import-time
# dep but stopped declaring any nvidia-* wheels, so a fresh install fails to
# import ("ImportError: libcudart.so.13"). 1.26.0 imports standalone and
# lazy-loads CUDA at session create (torch's nvidia/cu13 wheels provide it).
RUN --mount=type=cache,target=/root/.cache/uv \
    uv pip uninstall --system onnxruntime || true && \
    uv pip install --system "onnxruntime-gpu>=1.19.0,<1.27"

COPY headroom/ headroom/
RUN --mount=type=cache,target=/root/.cache/uv \
    uv pip install --system --no-deps --reinstall-package headroom-ai .

# Build SmartCrusher PyO3 extension.
# Workspace target dir is /build/target (Cargo.toml is at /build root via
# the workspace inheritance). Per-crate path was wrong and reset every build.
# CARGO_BUILD_JOBS limits parallelism to avoid OOM in Docker Desktop VM
# during the large Rust compile (esaxx-rs, magika, fastembed all heavy).
ENV CARGO_BUILD_JOBS=4
RUN --mount=type=cache,target=/root/.cargo/registry \
    --mount=type=cache,target=/build/target \
    maturin build --release \
        --manifest-path crates/headroom-py/Cargo.toml \
        --out /tmp/wheels && \
    uv pip install --system /tmp/wheels/*.whl

# Bake the Kompress model + tokenizer into /opt/hf-cache (HF_HOME) for offline
# runtime. Drive the download through the library's OWN loader
# (KompressCompressor.preload) instead of hardcoding repo ids here: preload()
# resolves HF_MODEL_ID and the transitive tokenizer (answerdotai/ModernBERT-base)
# straight from source, so a future upstream model bump can't leave this
# Dockerfile baking a stale model — the exact silent no-op this guards against.
# It also pulls only the first loadable ONNX artifact (int8-wo, ~261MB), not
# every variant. Pin the ONNX backend so the baked set (onnx weights + tokenizer)
# is provably sufficient and the PyTorch fallback — which would need un-baked
# ModernBERT weights — can never fire offline. cd /tmp so the /build/headroom/
# source tree doesn't shadow the installed package carrying _core.so.
# Fails the build (exit 1) if weights can't be fetched after 3 attempts, rather
# than shipping an image that silently no-ops at runtime.
RUN if echo ",${HEADROOM_EXTRAS}," | grep -q ",ml,"; then \
        ok=0; \
        for i in 1 2 3; do \
            if ( cd /tmp && HEADROOM_KOMPRESS_BACKEND=onnx python -c "\
from headroom.transforms.kompress_compressor import KompressCompressor; \
print('Kompress baked, backend=', KompressCompressor().preload())" ); then \
                ok=1; \
                break; \
            fi; \
            echo "kompress preload attempt $i failed, retrying"; \
            sleep 10; \
        done; \
        if [ "$ok" != 1 ]; then \
            echo 'FATAL: Kompress weights failed to bake after 3 attempts'; \
            exit 1; \
        fi; \
    else \
        mkdir -p /opt/hf-cache; \
    fi

# Build-time verification: fail fast on silent install issues.
# cd to /tmp so the local /build/headroom/ source dir doesn't shadow the
# installed package (which is the one carrying _core.so).
RUN cd /tmp && python -c "\
import headroom._core; \
import torch; \
import onnxruntime as ort; \
import tree_sitter_language_pack as tslp; \
assert 'CUDAExecutionProvider' in ort.get_available_providers(), 'onnxruntime-gpu missing CUDA EP'; \
assert hasattr(tslp, 'get_language'), 'tslp API broken (1.6.3 rename?)'; \
print('verify OK: torch', torch.__version__, '| ort providers', ort.get_available_providers()); \
"

# Verify Kompress actually COMPRESSES under the exact offline env the runtime
# uses. The historical failure was silent — a missing model/tokenizer made
# compress() return its input unchanged. This turns that into a hard build
# failure instead of a latent prod no-op.
RUN if echo ",${HEADROOM_EXTRAS}," | grep -q ",ml,"; then \
        cd /tmp && TRANSFORMERS_OFFLINE=1 HF_HUB_OFFLINE=1 \
        HEADROOM_KOMPRESS_BACKEND=onnx HF_HOME=/opt/hf-cache python -c "\
from headroom.transforms.kompress_compressor import KompressCompressor; \
src='The quick brown fox jumps over the lazy dog. ' * 40; \
out=KompressCompressor().compress(src); \
assert out.compressed != src and len(out.compressed) < len(src), \
    'Kompress no-op offline: weights/tokenizer not baked correctly'; \
print('Kompress offline OK:', len(src), '->', len(out.compressed)); \
"; \
    fi

# ---------- Stage 2: runtime ----------
FROM nvidia/cuda:${CUDA_VERSION}-cudnn-runtime-ubuntu${UBUNTU_VERSION} AS runtime

ARG PYTHON_VERSION

ENV DEBIAN_FRONTEND=noninteractive \
    PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    HEADROOM_HOST=0.0.0.0 \
    HF_HOME=/opt/hf-cache \
    TRANSFORMERS_OFFLINE=1 \
    HEADROOM_KOMPRESS_BACKEND=onnx

RUN echo 'Acquire::Retries "3";' > /etc/apt/apt.conf.d/80-retries && \
    echo 'Acquire::http::Timeout "30";' >> /etc/apt/apt.conf.d/80-retries && \
    echo 'Acquire::ForceIPv4 "true";' >> /etc/apt/apt.conf.d/80-retries

# Runtime needs only python + curl (healthcheck). Drop toolchain/dev libs.
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        curl \
        ca-certificates \
        python${PYTHON_VERSION} \
        python${PYTHON_VERSION}-venv && \
    ln -sf /usr/bin/python${PYTHON_VERSION} /usr/local/bin/python && \
    ln -sf /usr/bin/python${PYTHON_VERSION} /usr/local/bin/python3 && \
    rm -f /usr/lib/python${PYTHON_VERSION}/EXTERNALLY-MANAGED && \
    rm -rf /var/lib/apt/lists/*

# Ubuntu 24.04 ships with a default `ubuntu` user at uid/gid 1000. Drop
# it BEFORE the COPYs so --chown lands in the same layer as the data
# (a separate `chown -R` later would duplicate the data into a new
# layer — that bug added 3.75 GB to the previous build).
RUN userdel -r ubuntu 2>/dev/null || true && \
    groupadd --gid 1000 nonroot && \
    useradd --uid 1000 --gid nonroot --create-home nonroot && \
    mkdir -p /home/nonroot/.headroom /data && \
    chown -R nonroot:nonroot /home/nonroot /data

# Copy installed Python packages, headroom CLI, and baked HF cache.
# HF cache is chown'd in-place to avoid the duplicate-layer bug.
COPY --from=builder /usr/local/lib/python${PYTHON_VERSION}/dist-packages /usr/local/lib/python${PYTHON_VERSION}/dist-packages
COPY --from=builder /usr/lib/python3/dist-packages /usr/lib/python3/dist-packages
COPY --from=builder /usr/local/bin/headroom /usr/local/bin/headroom
COPY --from=builder --chown=nonroot:nonroot /opt/hf-cache /opt/hf-cache

USER nonroot
WORKDIR /home/nonroot

EXPOSE 8787

# Cold start with [ml] takes ~25-90s (torch init).
HEALTHCHECK --interval=30s --timeout=5s --start-period=120s --retries=3 \
    CMD curl --fail --silent http://127.0.0.1:8787/readyz || exit 1

ENTRYPOINT ["headroom", "proxy"]
CMD ["--host", "0.0.0.0", "--port", "8787"]
