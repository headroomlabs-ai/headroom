# Copy this file to .env and fill in real values before running in production.
# IMPORTANT: Change NEO4J_AUTH before deploying — default credentials are insecure.
NEO4J_AUTH=neo4j/CHANGEME

# Atlas Cloud OpenAI-compatible setup
ATLASCLOUD_API_KEY=your-atlascloud-api-key
ATLASCLOUD_BASE_URL=https://api.atlascloud.ai/v1
# Default validated Atlas model used by the built-in provider factory.
ATLASCLOUD_MODEL=qwen/qwen3-32b

# Optional: point Headroom's OpenAI-compatible proxy traffic at Atlas Cloud.
OPENAI_TARGET_API_URL=https://api.atlascloud.ai/v1
OPENAI_API_KEY=your-openai-compatible-api-key
